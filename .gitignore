# Single .gitignore for the whole repo. Patterns are unanchored, so they match
# at any depth (e.g. node_modules/ also ignores app/node_modules/).

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build / output
.next/
out/
build/
dist/
coverage/

# Env — all env files. Secrets live in app/.env.local (never committed);
# required vars are documented in the README.
.env
.env.*

# TypeScript / Next
*.tsbuildinfo
next-env.d.ts

# Editors / OS
.DS_Store
*.pem
.vscode/
.idea/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Deploy / services
.vercel
.supabase/
