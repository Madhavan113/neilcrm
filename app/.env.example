# Copy to .env.local and fill in. .env.local is gitignored; this template is committed.

# Anthropic (Claude API) — AI drafting
ANTHROPIC_API_KEY=

# Apollo.io — email/company enrichment
APOLLO_API_KEY=

# Supabase — browser-safe (used by the client + auth phase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase — SERVER ONLY. Bypasses Row-Level Security. Never expose to the browser.
SUPABASE_SECRET_KEY=
# Used to verify auth JWTs (auth phase)
SUPABASE_JWKS_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
